rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from an authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the caller a member of the given Haushalt?
    function isMember(haushaltsId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/haushalte/$(haushaltsId)).data.memberIds;
    }

    // Helper: is the caller the admin of the given Haushalt?
    function isAdmin(haushaltsId) {
      return isAuth() && get(/databases/$(database)/documents/haushalte/$(haushaltsId)).data.adminId == request.auth.uid;
    }

    // Helper: authenticated caller's household id from users/{uid}
    function myHaushaltsId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.haushaltsId;
    }

    // ── Haushalte ─────────────────────────────────────────────────────────────
    match /haushalte/{haushaltsId} {
      // Any authenticated user may read haushalte so they can look up a haushalt
      // by invite code before joining.
      allow read: if isAuth();
      allow create: if isAuth();
      // Admin may change anything.
      allow update: if isAdmin(haushaltsId);
      // Members may update ONLY their own display-name entry inside memberNames.
      allow update: if isMember(haushaltsId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["memberNames"]) &&
        request.resource.data.memberNames.diff(resource.data.memberNames).changedKeys().hasOnly([request.auth.uid]);
      // A new user may join by adding only themselves to memberIds (+ their name to memberNames).
      allow update: if isAuth() &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["memberIds", "memberNames"]) &&
        request.auth.uid in request.resource.data.memberIds;
      allow delete: if isAdmin(haushaltsId);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Read own user doc or users from same Haushalt
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        resource.data.haushaltsId == myHaushaltsId()
      );
      // Create limited to own doc or admin creating a member doc inside own Haushalt.
      allow create: if isAuth() && (
        request.auth.uid == userId ||
        (
          request.resource.data.haushaltsId == myHaushaltsId() &&
          isAdmin(myHaushaltsId())
        )
      );

      // Self-update for own profile fields.
      allow update: if isAuth() && request.auth.uid == userId;

      // Admin may update only permissions for users in same Haushalt.
      allow update: if isAuth() &&
        isAdmin(resource.data.haushaltsId) &&
        resource.data.haushaltsId == myHaushaltsId() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["permissions"]);

      allow delete: if false;
    }

    // ── Abholungen ────────────────────────────────────────────────────────────
    match /abholungen/{abholungId} {
      allow read: if isAuth() && isMember(resource.data.haushaltsId);
      allow create: if isAuth() &&
        isMember(request.resource.data.haushaltsId) &&
        request.resource.data.creatorId == request.auth.uid;
      // Creator can fully edit their own pickup.
      allow update: if isAuth() &&
        resource.data.creatorId == request.auth.uid &&
        request.resource.data.creatorId == resource.data.creatorId &&
        request.resource.data.haushaltsId == resource.data.haushaltsId;
      // Any haushalt member can respond (only response fields may change).
      allow update: if isAuth() &&
        isMember(resource.data.haushaltsId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "respondedBy", "responseNote", "respondedAt", "updatedAt"]) &&
        request.resource.data.creatorId == resource.data.creatorId &&
        request.resource.data.haushaltsId == resource.data.haushaltsId;
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notificationId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
  }
}
